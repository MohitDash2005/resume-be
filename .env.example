PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ai_resume_analyzer?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ai_resume_analyzer?retryWrites=true&w=majority

# JWT secrets — use long random strings in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# URLs
CLIENT_URL=https://your-frontend-url.com
SERVER_URL=https://your-backend-url.onrender.com

# File upload
MAX_FILE_SIZE_MB=5

# OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
